    "name": "Bandwidth Toll-Free Verification API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Bandwidth Toll-Free Verification API enables developers to programmatically submit and manage toll-free number verification requests for A2P messaging compliance. It automates the verification submission process, allowing developers to view and update the verification status of their toll-free numbers. This API helps ensure that toll-free messaging traffic complies with carrier requirements and regulations including the Telephone Consumer Protection Act (TCPA).\n\nContact Support:\n Name: Bandwidth Support",
      "type": "text/plain"
    }
  }
