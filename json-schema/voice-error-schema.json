{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/bandwidth/refs/heads/main/json-schema/voice-error-schema.json",
  "title": "Error",
  "description": "Error schema from Bandwidth voice API",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "The error type URI"
    },
    "description": {
